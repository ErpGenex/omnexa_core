  "modules": [
    "students",
    "teachers",
    "courses",
    "attendance",
    "grades",
    "assignments",
    "exams",
    "fees",
    "library",
    "hr"
  ],
  "isolation": {
    "pages": true,
    "menus": true,
    "workspaces": true,
    "dashboards": true,
    "reports": true,
    "permissions": true,
    "shortcuts": true,
    "navbar_items": true,
    "modules": true
  },
  "navigation": {
    "sidebar": {
      "enabled": true,
      "collapsible": true,
      "position": "left"
    },
    "navbar": {
      "enabled": true,
      "position": "top",
      "search_enabled": true,
      "notifications_enabled": true,
      "user_menu_enabled": true
    },
    "breadcrumb": {
      "enabled": true,
      "position": "top"
    }
  },
  "dashboard": {
    "layout": "grid",
    "columns": 12,
    "default_widgets": [
      "kpis",
      "quick_actions",
      "today_tasks",
      "charts",
      "recent_activities",
      "notifications"
    ]
  },
  "features": {
    "student_management": true,
    "teacher_management": true,
    "course_management": true,
    "attendance_tracking": true,
    "grade_management": true,
    "assignment_management": true,
    "exam_management": true,
    "fee_management": true,
    "library_management": true,
    "parent_portal": true
  },
  "integrations": {
    "learning_management_systems": ["moodle", "canvas", "blackboard"],
    "library_systems": ["koha", "evergreen"],
    "payment_gateways": ["stripe", "paypal"],
    "communication_systems": ["twilio", "sendgrid"]
  },
  "security": {
    "ferpa_compliant": true,
    "data_encryption": true,
    "audit_logging": true,
    "role_based_access": true,
    "session_timeout": 1800
  },
  "performance": {
    "lazy_loading": true,
    "caching_enabled": true,
    "bundle_optimization": true,
    "image_optimization": true
  }
}
