    {
      "portal_id": "healthcare_radiology",
      "portal_name": "Radiology Portal",
      "role": "healthcare_radiology",
      "url": "/app/healthcare/radiology"
    },
    {
      "portal_id": "healthcare_cashier",
      "portal_name": "Cashier Portal",
      "role": "healthcare_cashier",
      "url": "/app/healthcare/cashier"
    },
    {
      "portal_id": "healthcare_medical_records",
      "portal_name": "Medical Records Portal",
      "role": "healthcare_medical_records",
