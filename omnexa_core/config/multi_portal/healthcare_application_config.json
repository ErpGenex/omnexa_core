  "modules": [
    "patients",
    "appointments",
    "encounters",
    "admissions",
    "medications",
    "laboratory",
    "radiology",
    "pharmacy",
    "billing",
    "insurance"
  ],
  "isolation": {
    "pages": true,
    "menus": true,
    "workspaces": true,
    "dashboards": true,
    "reports": true,
    "permissions": true,
    "shortcuts": true,
    "navbar_items": true,
    "modules": true
  },
  "navigation": {
    "sidebar": {
      "enabled": true,
      "collapsible": true,
      "position": "left"
    },
    "navbar": {
      "enabled": true,
      "position": "top",
      "search_enabled": true,
      "notifications_enabled": true,
      "user_menu_enabled": true
    },
    "breadcrumb": {
      "enabled": true,
      "position": "top"
    }
  },
  "dashboard": {
    "layout": "grid",
    "columns": 12,
    "default_widgets": [
      "kpis",
      "quick_actions",
      "today_tasks",
      "charts",
      "recent_activities",
      "notifications"
    ]
  },
  "features": {
    "patient_management": true,
    "appointment_scheduling": true,
    "electronic_medical_records": true,
    "prescription_management": true,
    "laboratory_integration": true,
    "radiology_integration": true,
    "pharmacy_management": true,
    "billing_integration": true,
    "insurance_integration": true
  },
  "integrations": {
    "lab_systems": ["lab_info", "quest_diagnostics"],
    "radiology_systems": ["pacs", "dicom"],
    "pharmacy_systems": ["epic", "cerner"],
    "insurance_systems": ["blue_cross", "aetna"]
  },
  "security": {
    "hipaa_compliant": true,
    "data_encryption": true,
    "audit_logging": true,
    "role_based_access": true,
    "session_timeout": 1800
  },
  "performance": {
    "lazy_loading": true,
    "caching_enabled": true,
    "bundle_optimization": true,
    "image_optimization": true
  }
}
