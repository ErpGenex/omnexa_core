          {
            "id": "items",
            "title": "Items",
            "icon": "inventory_2",
            "route": "/app/commerce/warehouse/items"
          },
          {
            "id": "item_groups",
            "title": "Item Groups",
            "icon": "category",
            "route": "/app/commerce/warehouse/item-groups"
