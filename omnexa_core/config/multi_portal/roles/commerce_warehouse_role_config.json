    "allowed_doctypes": [
      "stock_entry",
      "stock_transfer",
      "stock_reconciliation",
      "item",
      "warehouse",
      "purchase_receipt",
      "purchase_order"
    ],
    "allowed_actions": [
      "create",
      "read",
      "update"
    ],
    "restricted_doctypes": [
      "sales_order",
      "customer_management",
      "financial_records",
      "hr_records"
    ]
  },
  "reports": [
    {
      "id": "stock_report",
      "title": "Stock Report",
      "route": "/app/commerce/warehouse/reports/stock"
    },
    {
      "id": "valuation_report",
      "title": "Valuation Report",
      "route": "/app/commerce/warehouse/reports/valuation"
    }
  ],
  "notifications": [
    "low_stock_alert",
    "stock_transfer_request",
    "purchase_receipt_ready",
    "reconciliation_required"
  ]
}
