      },
      {
        "id": "branch_staff",
        "title": "Branch Staff",
        "value": "count",
        "source": "healthcare_practitioner",
        "filter": "branch"
      },
      {
        "id": "branch_revenue",
        "title": "Branch Revenue",
        "value": "sum",
        "source": "payment",
        "filter": "branch_month"
      },
      {
        "id": "branch_occupancy",
