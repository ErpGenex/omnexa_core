  "permissions": {
    "allowed_doctypes": [
      "payment",
      "invoice",
      "refund",
      "cash_register",
      "insurance_claim"
    ],
    "allowed_actions": [
      "create",
      "read",
      "update"
    ],
    "restricted_doctypes": [
      "patient",
      "healthcare_encounter",
      "prescription",
      "medical_records"
    ]
  },
  "reports": [
    {
      "id": "collection_report",
      "title": "Collection Report",
      "route": "/app/healthcare/cashier/reports/collection"
    },
    {
      "id": "cash_report",
      "title": "Cash Report",
      "route": "/app/healthcare/cashier/reports/cash"
    }
  ],
  "notifications": [
    "payment_received",
    "invoice_due",
    "refund_request",
    "claim_approved"
  ]
}
