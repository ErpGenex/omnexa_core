      "support_ticket",
      "return",
      "customer",
      "feedback",
      "communication"
    ],
    "allowed_actions": [
      "create",
      "read",
      "update"
    ],
    "restricted_doctypes": [
      "sales_order",
      "purchase_order",
      "inventory_management",
      "financial_records"
    ]
  },
  "reports": [
    {
      "id": "support_report",
      "title": "Support Report",
      "route": "/app/commerce/customer-service/reports/support"
    },
    {
      "id": "satisfaction_report",
      "title": "Satisfaction Report",
      "route": "/app/commerce/customer-service/reports/satisfaction"
    }
  ],
  "notifications": [
    "new_ticket",
    "ticket_escalated",
    "return_request",
    "customer_feedback"
  ]
}
