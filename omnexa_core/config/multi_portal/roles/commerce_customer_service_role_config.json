{
  "role_id": "commerce_customer_service",
  "role_name": "Customer Service",
  "application": "commerce",
  "portal": "commerce_customer_service",
  "dashboard": {
    "kpis": [
      {
        "id": "open_tickets",
        "title": "Open Tickets",
        "value": "count",
        "source": "support_ticket",
        "filter": "open"
      },
      {
        "id": "tickets_resolved_today",
        "title": "Tickets Resolved Today",
        "value": "count",
        "source": "support_ticket",
        "filter": "resolved_today"
      },
      {
        "id": "pending_returns",
        "title": "Pending Returns",
        "value": "count",
        "source": "return",
        "filter": "pending"
      },
      {
        "id": "customer_satisfaction",
        "title": "Customer Satisfaction",
        "value": "percentage",
        "source": "feedback",
        "filter": "current"
      }
    ],
    "quick_actions": [
      {
        "id": "create_ticket",
        "title": "Create Ticket",
        "action": "create",
        "doctype": "support_ticket"
      },
      {
        "id": "process_return",
        "title": "Process Return",
        "action": "update",
        "doctype": "return"
      },
      {
        "id": "view_customer",
        "title": "View Customer",
        "action": "read",
        "doctype": "customer"
      },
      {
        "id": "send_communication",
        "title": "Send Communication",
        "action": "create",
        "doctype": "communication"
      }
