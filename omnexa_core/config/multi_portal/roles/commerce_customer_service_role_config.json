          },
          {
            "id": "ticket_history",
            "title": "Ticket History",
            "icon": "history",
            "route": "/app/commerce/customer-service/ticket-history"
          }
        ]
      },
      {
        "title": "Returns",
        "items": [
          {
            "id": "returns",
            "title": "Returns",
            "icon": "refund",
            "route": "/app/commerce/customer-service/returns"
          },
          {
            "id": "return_history",
            "title": "Return History",
            "icon": "history",
            "route": "/app/commerce/customer-service/return-history"
          }
        ]
      },
      {
        "title": "Customers",
        "items": [
          {
            "id": "customers",
            "title": "Customers",
            "icon": "people",
            "route": "/app/commerce/customer-service/customers"
          },
          {
            "id": "customer_feedback",
            "title": "Customer Feedback",
            "icon": "feedback",
            "route": "/app/commerce/customer-service/customer-feedback"
          }
        ]
      },
      {
        "title": "Reports",
        "items": [
          {
            "id": "support_report",
            "title": "Support Report",
            "icon": "assessment",
            "route": "/app/commerce/customer-service/reports/support"
