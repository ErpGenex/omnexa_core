    "widgets": [
      {
        "id": "open_tickets",
        "title": "Open Tickets",
        "type": "list",
        "source": "support_ticket"
      },
      {
        "id": "pending_returns",
        "title": "Pending Returns",
        "type": "list",
        "source": "return"
      },
      {
        "id": "recent_feedback",
        "title": "Recent Feedback",
        "type": "list",
        "source": "feedback"
      }
    ],
    "charts": [
      {
        "id": "ticket_trend",
        "title": "Ticket Trend",
        "type": "line",
        "source": "support_ticket"
      },
      {
        "id": "satisfaction_score",
        "title": "Satisfaction Score",
        "type": "bar",
        "source": "feedback"
      }
    ]
